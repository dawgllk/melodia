# Spotify API credentials (from Spotify Developer Dashboard)
# Used for server-to-server authentication and Spotify OAuth
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=https://your-public-backend-url/api/spotify/callback
FRONTEND_URL=http://localhost:4200
PORT=3000

MONGODB_URI=mongodb://localhost:27017/melodia

# Generated using:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
